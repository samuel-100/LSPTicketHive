generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ATTENDEE
  ORGANIZER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  CANCELLED
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
  TRANSFERRED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole  @default(ATTENDEE)
  avatarUrl     String?
  phone         String?
  emailVerified Boolean   @default(false)
  isPromoter    Boolean   @default(false)
  promoterInterests String[]  @default([])
  promoterBio   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization   Organization? @relation("OrganizationOwner")
  orders         Order[]
  tickets        Ticket[]
  reviews        Review[]
  savedEvents    SavedEvent[]
  following      Follow[]     @relation("UserFollowing")
  comments       EventComment[]

  @@index([email])
}

model Organization {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  description       String?
  logoUrl           String?
  website           String?
  stripeAccountId   String?          @unique
  stripeOnboarded   Boolean          @default(false)
  subscriptionTier  SubscriptionTier @default(FREE)
  platformFeeRate   Float            @default(2.0)
  ownerId           String           @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  owner     User      @relation("OrganizationOwner", fields: [ownerId], references: [id])
  events    Event[]
  payouts   Payout[]
  followers Follow[]

  @@index([slug])
}

model Event {
  id             String      @id @default(cuid())
  title          String
  slug           String
  description    String
  shortDesc      String?
  coverImageUrl  String?
  venue          String?
  address        String?
  city           String?
  country        String?
  latitude       Float?
  longitude      Float?
  isOnline       Boolean     @default(false)
  onlineUrl      String?
  startDate      DateTime
  endDate        DateTime
  timezone       String      @default("UTC")
  status         EventStatus @default(DRAFT)
  category       String?
  tags           String[]
  totalCapacity  Int
  organizationId String
  promotable     Boolean     @default(false)  // open to promoters?
  commissionRate Float       @default(10)      // % a promoter earns per sale
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  ticketTypes  TicketType[]
  orders       Order[]
  reviews      Review[]
  savedBy      SavedEvent[]

  @@unique([organizationId, slug])
  @@index([status, startDate])
  @@index([city, category])
}

model TicketType {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  currency      String   @default("USD")
  quantity      Int
  sold          Int      @default(0)
  maxPerOrder   Int      @default(10)
  salesStart    DateTime?
  salesEnd      DateTime?
  eventId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@index([eventId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @default(cuid())
  status          OrderStatus @default(PENDING)
  subtotal        Float
  platformFee     Float
  processingFee   Float
  total           Float
  currency        String      @default("USD")
  stripePaymentId String?     @unique
  userId          String
  eventId         String
  promoterId      String?     // attributed promoter (referral)
  commission      Float       @default(0)  // amount the promoter earns on this order
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  event   Event    @relation(fields: [eventId], references: [id])
  tickets Ticket[]

  @@index([userId])
  @@index([eventId])
  @@index([orderNumber])
}

model Ticket {
  id           String       @id @default(cuid())
  qrCode       String       @unique @default(cuid())
  status       TicketStatus @default(VALID)
  checkedInAt  DateTime?
  ticketTypeId String
  orderId      String
  userId       String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  order      Order      @relation(fields: [orderId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@index([qrCode])
  @@index([userId])
}

model Payout {
  id              String       @id @default(cuid())
  amount          Float
  currency        String       @default("USD")
  status          PayoutStatus @default(PENDING)
  stripePayoutId  String?      @unique
  organizationId  String
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model SavedEvent {
  id      String @id @default(cuid())
  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Follow {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())

  user         User         @relation("UserFollowing", fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model PromoterRequest {
  id             String   @id @default(cuid())
  organizationId String
  eventId        String
  category       String?  // event category, for interest matching
  commissionRate Float    @default(10)
  targetAudience String?  // e.g. "uni students, Afrobeats crowd"
  note           String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([category])
  @@index([organizationId])
}

model Conversation {
  id         String    @id @default(cuid())
  isGroup    Boolean   @default(false)
  name       String?   // group name
  userAId    String?   // 1-1 only
  userBId    String?   // 1-1 only
  eventId    String?   // optional context: a specific event
  lastMessageAt DateTime @default(now())
  createdAt  DateTime  @default(now())

  messages   Message[]
  members    ConversationMember[]

  @@index([userAId])
  @@index([userBId])
}

model ConversationMember {
  id             String  @id @default(cuid())
  conversationId String
  userId         String
  isAdmin        Boolean @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @default("")
  imageUrl       String?
  audioUrl       String?
  audioDuration  Int?      // seconds, for the voice-note waveform/length
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model EventLike {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([eventId])
}

model EventComment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([eventId])
}

model PromoCode {
  id             String   @id @default(cuid())
  code           String
  percentOff     Int      // 1-100
  maxUses        Int?     // null = unlimited
  usedCount      Int      @default(0)
  expiresAt      DateTime?
  active         Boolean  @default(true)
  organizationId String
  eventId        String?  // null = valid for all the org's events
  createdAt      DateTime @default(now())

  @@unique([organizationId, code])
  @@index([organizationId])
}
